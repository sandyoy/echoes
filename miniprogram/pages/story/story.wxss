/* 故事详情样式 */
.page {
  min-height: 100vh;
  padding: 30rpx;
}

.story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.story-tags {
  display: flex;
  gap: 12rpx;
}
.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  background: var(--accent-light);
  color: var(--accent);
  font-size: 22rpx;
}
.story-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.story-content {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  font-size: 32rpx;
  line-height: 1.9;
  color: var(--text-primary);
  box-shadow: var(--shadow);
  margin-bottom: 30rpx;
}

.story-audio {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}
.play-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: var(--accent-light);
  color: var(--accent);
  font-size: 28rpx;
}
.play-btn:active {
  opacity: 0.8;
}

.story-actions {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}
.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  border: 2rpx solid #e8d8c8;
  color: var(--text-secondary);
  font-size: 24rpx;
  background: transparent;
}

.related-section {
  margin-top: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.related-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.related-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
