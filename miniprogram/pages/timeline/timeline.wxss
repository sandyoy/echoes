/* 时间轴样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.timeline {
  padding: 0 30rpx;
}

.timeline-year-group {
  margin-bottom: 40rpx;
}

.year-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
}
.year-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--accent);
  margin-right: 16rpx;
}
.year-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.timeline-story {
  display: flex;
  align-items: flex-start;
  padding-left: 30rpx;
  position: relative;
}
.tl-line {
  width: 4rpx;
  height: 100%;
  background: var(--border);
  position: absolute;
  left: 10rpx;
  top: 0;
}
.timeline-story:last-child .tl-line {
  height: 50%;
}

.tl-card {
  flex: 1;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  margin-left: 20rpx;
  box-shadow: var(--shadow);
}
.tl-date {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 6rpx;
}
.tl-era {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  background: var(--accent-light);
  color: var(--accent);
  font-size: 20rpx;
  margin-bottom: 8rpx;
}
.tl-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
