/* 首页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 录音区域 */
.recording-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
}
.recording-section .title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.recording-section .subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

/* 录音按钮 */
.recording-btn-wrapper {
  margin-bottom: 40rpx;
}
.recording-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0e4d6, #e8d8c8);
  border: 6rpx solid var(--accent);
  box-shadow: 0 8rpx 24rpx rgba(196, 149, 106, 0.3);
  transition: all 0.2s;
  padding: 0;
  line-height: 1;
}
.recording-btn::after {
  border: none;
}
.recording-btn .icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}
.recording-btn .label {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.recording-btn.recording-active {
  background: linear-gradient(145deg, #f5d6c8, #ecc8b8);
  border-color: #e8734a;
  box-shadow: 0 8rpx 32rpx rgba(232, 115, 74, 0.4);
  animation: pulse 1s infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 模式切换 */
.mode-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.mode-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.mode-btn.active {
  background: var(--accent-light);
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 500;
}
.mode-btn:active {
  opacity: 0.8;
}

.mode-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 10rpx;
}

/* 文字输入 */
.type-input-area {
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}
.type-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  border: 2rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}
.submit-btn {
  margin-top: 20rpx;
  width: 100%;
}

/* 最近回忆区域 */
.recent-section {
  padding: 0 30rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.section-more {
  font-size: 26rpx;
  color: var(--accent);
}

/* 故事卡片 */
.story-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
}
.story-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.story-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: var(--accent-light);
  color: var(--accent);
  font-size: 22rpx;
}
.story-date {
  font-size: 22rpx;
  color: var(--text-muted);
}
.story-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* 录音提示 Toast */
.recording-toast {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  z-index: 999;
}
.recording-toast.show {
  opacity: 1;
}
.toast-icon {
  font-size: 32rpx;
}
