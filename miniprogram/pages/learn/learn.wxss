/* 学习首页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.card-grid {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: var(--shadow);
  gap: 24rpx;
}
.feature-card:active {
  opacity: 0.85;
}

.card-icon-area {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pinyin-bg {
  background: #fff0e6;
}
.math-bg {
  background: #e6f0ff;
}
.card-icon {
  font-size: 48rpx;
}

.card-info {
  flex: 1;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}
.card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 统计卡片 */
.stats-card {
  margin: 30rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.stats-card .stats-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-bottom: 2rpx solid var(--border);
}
.stat-row:last-child {
  border-bottom: none;
}
.stat-val {
  font-weight: 600;
  color: var(--accent);
}

/* 小贴士 */
.tip-card {
  margin: 0 30rpx 30rpx;
  background: #fffbf0;
  border: 2rpx solid #f0d6a0;
  border-radius: 16rpx;
  padding: 20rpx;
}
.tip-card .tip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #b8860b;
  margin-bottom: 8rpx;
}
.tip-card .tip-text {
  font-size: 24rpx;
  color: #8b7355;
  line-height: 1.6;
}
