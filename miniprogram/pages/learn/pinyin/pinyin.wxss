/* 拼音首页样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx 30rpx;
}
.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

.mode-section {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
  gap: 20rpx;
}
.mode-card:active {
  transform: scale(0.98);
}

.mode-icon-area {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sm-bg { background: #e8f5e9; }
.ym-bg { background: #e3f2fd; }
.ztr-bg { background: #fff3e0; }
.hh-bg { background: #fce4ec; }
.mode-icon {
  font-size: 40rpx;
}

.mode-info {
  flex: 1;
}
.mode-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.mode-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.mode-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* 查字 */
.lookup-section {
  padding: 24rpx 30rpx 0;
}
.lookup-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
  gap: 20rpx;
}
.lookup-icon {
  font-size: 40rpx;
}
.lookup-info {
  flex: 1;
}
.lookup-title {
  font-size: 30rpx;
  font-weight: 600;
}
.lookup-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.lookup-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* 打卡 */
.checkin-section {
  margin: 30rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.checkin-title {
  font-size: 28rpx;
  font-weight: 600;
}
.checkin-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.checkin-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.checkin-progress {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), #e8734a);
  border-radius: 10rpx;
  transition: width 0.5s;
}

.checkin-btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 40rpx;
  background: var(--accent);
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.checkin-btn.done {
  background: #e0d8d0;
  color: #999;
}
