<!-- AI采访页面 - 支持语音朗读 + 语音输入 -->
<view class="page">
  
  <view class="chat-container">
    
    <!-- 对话列表 -->
    <scroll-view class="chat-list" scroll-y scroll-into-view="bottom" scroll-with-animation lower-threshold="50">
      <view wx:for="{{messages}}" wx:key="index" id="bottom">
        <!-- AI消息 -->
        <view class="msg-row msg-ai" wx:if="{{item.role === 'ai'}}">
          <view class="msg-avatar">🤖</view>
          <view class="msg-content">
            <view class="msg-bubble ai-bubble">
              <text>{{item.content}}</text>
            </view>
            <!-- 语音播放按钮 -->
            <view class="voice-play-bar" wx:if="{{item.ttsUrl || item.ttsLoading}}" catchtap="onPlayTTS" data-index="{{index}}">
              <view class="play-btn {{item.ttsPlaying ? 'playing' : ''}}" wx:if="{{!item.ttsLoading}}">
                <text class="play-icon">{{item.ttsPlaying ? '⏸' : '🔊'}}</text>
              </view>
              <view class="play-btn loading" wx:elif="{{item.ttsLoading}}">
                <text class="play-icon">⏳</text>
              </view>
              <text class="play-label" wx:if="{{!item.ttsLoading}}">
                {{item.ttsPlaying ? '点击暂停' : '点击收听'}}
              </text>
              <text class="play-label" wx:elif="{{item.ttsLoading}}">生成语音中...</text>
            </view>
          </view>
        </view>
        
        <!-- 用户消息 -->
        <view class="msg-row msg-user" wx:else>
          <view class="msg-bubble user-bubble">
            <text>{{item.content}}</text>
          </view>
          <view class="msg-avatar">👤</view>
        </view>
      </view>
      
      <!-- 正在输入 -->
      <view class="msg-row msg-ai" wx:if="{{isThinking}}">
        <view class="msg-avatar">🤖</view>
        <view class="msg-bubble ai-bubble thinking">
          <text class="dot">.</text><text class="dot">.</text><text class="dot">.</text>
        </view>
      </view>
    </scroll-view>

    <!-- 开始采访的引导 -->
    <view class="start-guide" wx:if="{{messages.length === 0 && !isThinking}}">
      <view class="guide-icon">🎙️</view>
      <view class="guide-title">让AI陪你聊聊往事</view>
      <view class="guide-desc">你可以说：</view>
      <view class="guide-suggestions">
        <view class="suggestion-tag" bindtap="sendSuggestion" data-text="聊聊我小时候的事">👶 聊聊我小时候的事</view>
        <view class="suggestion-tag" bindtap="sendSuggestion" data-text="说说我的老家">🏠 说说我的老家</view>
        <view class="suggestion-tag" bindtap="sendSuggestion" data-text="我最难忘的一位老师">👨‍🏫 我最难忘的一位老师</view>
        <view class="suggestion-tag" bindtap="sendSuggestion" data-text="我第一份工作的经历">💼 我第一份工作的经历</view>
      </view>
    </view>

  </view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <view class="input-wrapper">
      <input 
        class="text-input"
        placeholder="打字告诉AI你的回忆..."
        bindinput="onInput"
        value="{{inputText}}"
        bindconfirm="sendMessage"
        confirm-type="send"
      />
    </view>
    <button class="send-btn" bindtap="sendMessage" disabled="{{!inputText.trim() || isThinking}}">
      <text>发送</text>
    </button>
    <!-- 语音输入按钮 - 按住说话 -->
    <view 
      class="voice-btn {{voicePress ? 'voice-active' : ''}}"
      bindtouchstart="onVoiceStart"
      bindtouchend="onVoiceEnd"
      bindtouchmove="onVoiceMove"
      catchtouchcancel="onVoiceEnd"
    >
      <text>{{voicePress ? '🎤' : '🎤'}}</text>
    </view>
  </view>

  <!-- 录音状态提示 -->
  <view class="voice-status {{voicePress ? 'voice-status-show' : ''}}">
    <view class="voice-status-dot {{voiceCancel ? 'cancel' : ''}}"></view>
    <text class="voice-status-text">
      {{voiceCancel ? '松手取消' : '正在录音...'}}
    </text>
  </view>

</view>
