/* AI采访样式 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-list {
  flex: 1;
  padding: 20rpx 30rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}
.msg-ai {
  justify-content: flex-start;
}
.msg-user {
  justify-content: flex-end;
}

.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.msg-ai .msg-avatar {
  margin-right: 16rpx;
}
.msg-user .msg-avatar {
  margin-left: 16rpx;
}

.msg-bubble {
  max-width: 520rpx;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}
.ai-bubble {
  background: var(--bg-card);
  color: var(--text-primary);
  border-top-left-radius: 4rpx;
  box-shadow: var(--shadow);
}
.user-bubble {
  background: var(--accent);
  color: #fff;
  border-top-right-radius: 4rpx;
}

/* 正在输入动画 */
.thinking {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 24rpx 32rpx;
}
.dot {
  font-size: 48rpx;
  line-height: 1;
  animation: blink 1.4s infinite;
  color: var(--text-muted);
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 开始引导 */
.start-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx 60rpx;
}
.guide-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.guide-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}
.guide-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}
.guide-suggestions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}
.suggestion-tag {
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  font-size: 28rpx;
  color: var(--accent);
  text-align: center;
}
.suggestion-tag:active {
  background: var(--accent-light);
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-card);
  border-top: 2rpx solid var(--border);
  gap: 12rpx;
}
.input-wrapper {
  flex: 1;
  background: var(--bg-primary);
  border-radius: 40rpx;
  padding: 0 24rpx;
}
.text-input {
  height: 72rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}
.send-btn {
  width: 100rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 40rpx;
  background: var(--accent);
  color: #fff;
  font-size: 26rpx;
  padding: 0;
}
.send-btn[disabled] {
  background: var(--border);
  color: var(--text-muted);
}
.voice-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--bg-primary);
  font-size: 32rpx;
  padding: 0;
}
