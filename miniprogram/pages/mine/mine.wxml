<!-- 个人中心 -->
<view class="page">
  
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="avatar">{{userInfo.nickname ? userInfo.nickname[0] : '?'}}</view>
    <view class="user-name">{{userInfo.nickname || '未登录'}}</view>
    <button class="login-btn" wx:if="{{!userInfo.nickname}}" bindtap="login">
      微信一键登录
    </button>
  </view>

  <!-- 统计 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalStories}}</text>
      <text class="stat-label">回忆条数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.thisYear}}</text>
      <text class="stat-label">今年新增</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.audioCount}}</text>
      <text class="stat-label">语音回忆</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goTimeline">
      <text class="menu-icon">📖</text>
      <text class="menu-text">我的时光轴</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="exportData">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出回忆</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于「往事可追忆」</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

</view>
